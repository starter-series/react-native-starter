# Google OAuth client IDs for expo-auth-session.
# Create them in Google Cloud Console -> APIs & Services -> Credentials.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Required. "Web application" client. Used for the Expo AuthSession proxy in dev.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optional until you ship standalone builds.
# Create an "iOS" client tied to your `ios.bundleIdentifier`.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Optional until you ship standalone Android builds.
# Create an "Android" client tied to your `android.package` + SHA-1 fingerprint.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
